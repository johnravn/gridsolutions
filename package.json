{
  "name": "grid",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.0.0",
  "scripts": {
    "dev": "vite --port 3000",
    "start": "vite --port 3000",
    "build": "vite build",
    "build:check": "vite build && tsc",
    "serve": "vite preview",
    "test": "node scripts/run-vitest.mjs run",
    "test:watch": "node scripts/run-vitest.mjs",
    "test:coverage": "node scripts/run-vitest.mjs run --coverage",
    "test:coverage:report": "node scripts/coverage-by-section.mjs",
    "test:integration": "node scripts/run-vitest.mjs run --config vitest.integration.config.ts",
    "test:kill-orphans": "node scripts/kill-vitest-orphans.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:all": "npm run test && npm run db:seed-test-users && RUN_INTEGRATION_TESTS=1 npm run test:integration && npm run test:e2e",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "db:types": "supabase gen types typescript --local > src/shared/types/database.types.ts",
    "db:types:remote": "supabase gen types typescript --project-id tlpgejkglrgoljgvpubn > src/shared/types/database.types.ts",
    "db:diff": "supabase db diff --use-migra -f",
    "db:reset": "node scripts/reset-with-data.js",
    "db:reset:schema-only": "node scripts/db-reset.mjs",
    "db:seed-email-vault-local": "node scripts/seed-local-email-vault.mjs",
    "db:push": "supabase db push",
    "db:migrate": "supabase migration new",
    "db:status": "supabase status",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:restart": "supabase stop && supabase start",
    "supabase:link": "supabase link --project-ref tlpgejkglrgoljgvpubn",
    "db:switch:local": "node scripts/switch-db.js local",
    "db:switch:remote": "node scripts/switch-db.js remote",
    "db:switch:status": "node scripts/switch-db.js status",
    "db:copy-data": "node scripts/copy-remote-data.js",
    "db:copy-auth": "node scripts/copy-auth.js",
    "db:copy-storage": "node scripts/copy-storage.js",
    "db:copy-avatars": "node scripts/copy-avatars.js",
    "db:sync-buckets": "node scripts/sync-buckets.js",
    "db:generate-seed": "node scripts/generate-seed.js",
    "db:reset:with-data": "node scripts/reset-with-data.js",
    "db:seed-test-users": "node scripts/seed-test-users.mjs",
    "conta:types": "openapi-typescript src/shared/api/conta/conta-external-api.json -o src/shared/api/conta/types.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.19",
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/interaction": "^6.1.19",
    "@fullcalendar/list": "^6.1.19",
    "@fullcalendar/react": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19",
    "@glowstudent/youversion": "^2.2.2",
    "@radix-ui/themes": "^3.2.1",
    "@supabase/supabase-js": "^2.87.1",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.2.2",
    "@tanstack/react-form": "^1.33.2",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-pacer": "^0.19.1",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-router": "^1.130.2",
    "@tanstack/react-router-devtools": "^1.131.5",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.18",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.22",
    "html2canvas": "^1.4.1",
    "iconoir-react": "^7.11.0",
    "ics": "^3.8.1",
    "jspdf": "^4.2.1",
    "libphonenumber-js": "^1.12.23",
    "next-themes": "^0.4.6",
    "norwegian-postalcodes-mapper": "^1.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-phone-number-input": "^3.4.12",
    "recharts": "^3.3.0",
    "tailwindcss": "^4.0.6",
    "temporal-polyfill": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@types/jspdf": "^1.3.3",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/react-phone-number-input": "^3.0.17",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser": "^3.0.5",
    "@vitest/coverage-v8": "^3.0.5",
    "baseline-browser-mapping": "^2.9.7",
    "eslint-plugin-storybook": "^10.4.6",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.10.1",
    "playwright": "^1.61.1",
    "prettier": "^3.5.3",
    "storybook": "^10.4.6",
    "supabase": "^2.74.4",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.5",
    "web-vitals": "^4.2.4"
  }
}
